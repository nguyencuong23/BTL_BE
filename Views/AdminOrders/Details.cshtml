@model QuanLyThuVienTruongHoc.Models.Commerce.Order
@using QuanLyThuVienTruongHoc.Models.Commerce

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0"><i class="fas fa-receipt me-2"></i>@Model.OrderCode</h2>
        <div class="text-muted">Tạo lúc @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
</div>

@await Html.PartialAsync("_Alerts")

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Khách hàng</h5>
                <div><b>Họ tên</b>: @Model.User?.FullName</div>
                <div><b>Email</b>: @Model.User?.Email</div>
                <div><b>SĐT</b>: @Model.User?.PhoneNumber</div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Giao hàng</h5>
                <div><b>Người nhận</b>: @Model.ReceiverName</div>
                <div><b>SĐT</b>: @Model.ReceiverPhone</div>
                <div><b>Địa chỉ</b>: @Model.ShippingAddress</div>
                @if (!string.IsNullOrWhiteSpace(Model.Note))
                {
                    <div class="mt-2"><b>Ghi chú</b>: @Model.Note</div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Thao tác</h5>

                <div class="d-flex flex-wrap gap-2">
                    <form asp-action="UpdateStatus" method="post" class="d-flex gap-2 align-items-center">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.OrderId" />
                        <select name="status" class="form-select" style="min-width: 240px;">
                            @foreach (var s in Enum.GetValues<OrderStatus>())
                            {
                                <option value="@((int)s)" selected="@(Model.Status == s)">@s</option>
                            }
                        </select>
                        <button class="btn btn-primary" type="submit">Cập nhật trạng thái</button>
                    </form>

                    @if (Model.PaymentMethod == PaymentMethod.BankTransfer && Model.PaymentStatus != PaymentStatus.Paid)
                    {
                        <form asp-action="ConfirmBankTransfer" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.OrderId" />
                            <button class="btn btn-success" type="submit">Xác nhận chuyển khoản</button>
                        </form>
                    }

                    <form asp-action="Cancel" method="post" onsubmit="return confirm('Hủy đơn và hoàn kho?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.OrderId" />
                        <button class="btn btn-outline-danger" type="submit">Hủy đơn</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Thanh toán</h5>
                <div><b>Phương thức</b>: @Model.PaymentMethod</div>
                <div><b>Trạng thái</b>: @Model.PaymentStatus</div>
                @if (!string.IsNullOrWhiteSpace(Model.BankTransferReference))
                {
                    <div class="text-muted small mt-2">Tham chiếu: @Model.BankTransferReference</div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Sản phẩm</h5>
                <ul class="list-unstyled mb-3">
                    @foreach (var it in Model.Items)
                    {
                        <li class="d-flex justify-content-between border-bottom py-2">
                            <span class="me-2">@it.Book?.Title x @it.Quantity</span>
                            <span class="text-nowrap">@it.LineTotal.ToString("N0") đ</span>
                        </li>
                    }
                </ul>
                <div class="d-flex justify-content-between">
                    <span>Tạm tính</span><b>@Model.Subtotal.ToString("N0") đ</b>
                </div>
                <div class="d-flex justify-content-between">
                    <span>Ship</span><b>@Model.ShippingFee.ToString("N0") đ</b>
                </div>
                <div class="d-flex justify-content-between">
                    <span>Giảm giá</span><b>@Model.Discount.ToString("N0") đ</b>
                </div>
                <hr />
                <div class="d-flex justify-content-between fs-5">
                    <span>Tổng</span><b>@Model.Total.ToString("N0") đ</b>
                </div>
            </div>
        </div>
    </div>
</div>

