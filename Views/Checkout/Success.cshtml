@model QuanLyThuVienTruongHoc.Models.Commerce.Order
@using QuanLyThuVienTruongHoc.Models.Commerce

@{
    ViewData["Title"] = "Đặt hàng thành công";
    Layout = "~/Views/Shared/_ClientLayout.cshtml";
}

<div class="container py-4">
    <div class="alert alert-success">
        <div class="fw-bold fs-5">Đặt hàng thành công</div>
        <div>Mã đơn: <b>@Model.OrderCode</b></div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Thông tin nhận hàng</h5>
                    <div><b>Người nhận</b>: @Model.ReceiverName</div>
                    <div><b>SĐT</b>: @Model.ReceiverPhone</div>
                    <div><b>Địa chỉ</b>: @Model.ShippingAddress</div>
                    @if (!string.IsNullOrWhiteSpace(Model.Note))
                    {
                        <div class="mt-2"><b>Ghi chú</b>: @Model.Note</div>
                    }
                </div>
            </div>

            <div class="card border-0 shadow-sm mt-3">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Trạng thái thanh toán</h5>
                    <div><b>Phương thức</b>: @Model.PaymentMethod</div>
                    <div><b>Trạng thái</b>: @Model.PaymentStatus</div>
                    @if (Model.PaymentMethod == PaymentMethod.BankTransfer)
                    {
                        <div class="text-muted small mt-2">Đơn hàng của bạn đang chờ xác nhận chuyển khoản từ admin.</div>
                    }
                    else
                    {
                        <div class="text-muted small mt-2">Bạn sẽ thanh toán khi nhận hàng (COD).</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Chi tiết đơn</h5>
                    <ul class="list-unstyled mb-3">
                        @foreach (var it in Model.Items)
                        {
                            <li class="d-flex justify-content-between border-bottom py-2">
                                <span class="me-2">@it.Book?.Title x @it.Quantity</span>
                                <span class="text-nowrap">@it.LineTotal.ToString("N0") đ</span>
                            </li>
                        }
                    </ul>
                    <div class="d-flex justify-content-between">
                        <span>Tạm tính</span><b>@Model.Subtotal.ToString("N0") đ</b>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Phí ship</span><b>@Model.ShippingFee.ToString("N0") đ</b>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Giảm giá</span><b>@Model.Discount.ToString("N0") đ</b>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between fs-5">
                        <span>Tổng</span><b>@Model.Total.ToString("N0") đ</b>
                    </div>

                    <a asp-controller="Orders" asp-action="Details" asp-route-id="@Model.OrderId" class="btn btn-outline-primary w-100 mt-3">
                        Xem đơn hàng
                    </a>
                    <a asp-controller="Client" asp-action="Search" class="btn btn-primary w-100 mt-2">
                        Tiếp tục mua sắm
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

